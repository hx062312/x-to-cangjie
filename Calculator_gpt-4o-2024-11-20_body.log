main(args: Array<String>): Int32 {
    if (args.size == 0) {
        printUsage()
        return 0
    }

    let calc = Calculator()
    let operation = args[0].toLowerCase()

    try {
        if (operation == "add" || operation == "+") {
            if (args.size != 3) throw IllegalArgumentException("add requires 2 numbers")
            let result = calc.performAdd(parseInt(args[1]), parseInt(args[2]))
            printResult(result)
        } else if (operation == "sub" || operation == "-") {
            if (args.size != 3) throw IllegalArgumentException("sub requires 2 numbers")
            let result = calc.performSub(parseInt(args[1]), parseInt(args[2]))
            printResult(result)
        } else if (operation == "mul" || operation == "*") {
            if (args.size != 3) throw IllegalArgumentException("mul requires 2 numbers")
            let result = calc.performMul(parseInt(args[1]), parseInt(args[2]))
            printResult(result)
        } else if (operation == "div" || operation == "/") {
            if (args.size != 3) throw IllegalArgumentException("div requires 2 numbers")
            let result = calc.performDiv(parseInt(args[1]), parseInt(args[2]))
            printResult(result)
        } else if (operation == "history" || operation == "h") {
            for (entry in calc.getLogger().getHistory()) {
                println(entry)
            }
        } else if (operation == "help" || operation == "-h" || operation == "--help") {
            printUsage()
        } else {
            printErr("Unknown operation: " + operation)
            printUsage()
        }
    } catch (e: NumberFormatException) {
        printErr("Error: Please enter valid integers")
        return 1
    } catch (e: IllegalArgumentException) {
        printErr("Error: " + e.message)
        return 1
    }

    return 0
}
